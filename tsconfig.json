{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": [],
    "paths": {
      "poster/*": ["./poster/*"],
      "framework/*": ["./framework/*"],
      "lib/*": ["./lib/*"],
      "assets/*": ["./assets/*"]
    }
  },
  "include": [
    "poster/**/*.ts",
    "poster/**/*.vue",
    "framework/**/*.ts",
    "framework/**/*.vue",
    "lib/**/*.ts",
    "env.d.ts"
  ]
}
